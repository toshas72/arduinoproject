#include <Wire.h>
#include "rgb_lcd.h"

rgb_lcd lcd;

// Пины
const int rotaryPin = A0;     
const int button1Pin = 3;     
const int button2Pin = 2;     
const int helpButtonPin = 6;  
const int bulb1Pin = 7;       
const int bulb2Pin = 8;       

// Состояния
bool manualLamp1 = false;
bool manualLamp2 = false;
bool autoLamp1 = false;
bool autoLamp2 = false;
bool helpEnabled = true;

// Кнопки
bool lastButton1State = HIGH;
bool lastButton2State = HIGH;
bool lastHelpButtonState = HIGH;

// Зоны
const int centerValue = 512;
const int warningZone = 120;
const int dangerZone = 300;

// Мигание
unsigned long previousMillis = 0;
const unsigned long blinkInterval = 400; 
bool blinkState = false;

void setup() {
  pinMode(button1Pin, INPUT_PULLUP);
  pinMode(button2Pin, INPUT_PULLUP);
  pinMode(helpButtonPin, INPUT_PULLUP);

  pinMode(bulb1Pin, OUTPUT);
  pinMode(bulb2Pin, OUTPUT);

  lcd.begin(16, 2);
  lcd.setRGB(0, 255, 0);
  lcd.print("CENTER          ");
}

void loop() {

  
  unsigned long currentMillis = millis();
  if (currentMillis - previousMillis >= blinkInterval) {
    previousMillis = currentMillis;
    blinkState = !blinkState;
  }

  
  bool currentButton1State = digitalRead(button1Pin);
  if (currentButton1State == LOW && lastButton1State == HIGH) {
    manualLamp1 = !manualLamp1;
    delay(200);
  }
  lastButton1State = currentButton1State;

  bool currentButton2State = digitalRead(button2Pin);
  if (currentButton2State == LOW && lastButton2State == HIGH) {
    manualLamp2 = !manualLamp2;
    delay(200);
  }
  lastButton2State = currentButton2State;

  bool currentHelpButtonState = digitalRead(helpButtonPin);
  if (currentHelpButtonState == LOW && lastHelpButtonState == HIGH) {
    helpEnabled = !helpEnabled;
    delay(200);
  }
  lastHelpButtonState = currentHelpButtonState;

  
  int value = analogRead(rotaryPin);
  int deviation = value - centerValue;

  lcd.setCursor(0, 0);

  //help off
  if (!helpEnabled) {

    digitalWrite(bulb1Pin, manualLamp1 ? HIGH : LOW);
    digitalWrite(bulb2Pin, manualLamp2 ? HIGH : LOW);

    lcd.setRGB(0, 255, 0);
    lcd.print("HELP OFF        ");
  }

  //help on
  else {

    // ===== CENTER =====
    if (abs(deviation) < warningZone) {

      lcd.setRGB(0, 255, 0);
      lcd.print("CENTER          ");

      autoLamp1 = false;
      autoLamp2 = false;
    }

    // WARNING 
    else if (abs(deviation) < dangerZone) {

      lcd.setRGB(255, 200, 0);
      lcd.print("WARNING         ");

      autoLamp1 = false;
      autoLamp2 = false;
    }

    //  DANGER 
    else {

      if (deviation < 0) {
        autoLamp1 = true;
        autoLamp2 = false;

        
        if (manualLamp1) {
          lcd.setRGB(0, 255, 0);
          lcd.print("GOOD TO GO      ");
        } else {
          lcd.setRGB(255, 0, 0);
          lcd.print("DANGER LEFT     ");
        }
      }
      else {
        autoLamp2 = true;
        autoLamp1 = false;

        if (manualLamp2) {
          lcd.setRGB(0, 255, 0);
          lcd.print("GOOD TO GO      ");
        } else {
          lcd.setRGB(255, 0, 0);
          lcd.print("DANGER RIGHT    ");
        }
      }
    }

    // Управление лампами 

    // Лампа 1
    if (manualLamp1 || autoLamp1) {
      digitalWrite(bulb1Pin, blinkState ? HIGH : LOW);
    } else {
      digitalWrite(bulb1Pin, LOW);
    }

    // Лампа 2
    if (manualLamp2 || autoLamp2) {
      digitalWrite(bulb2Pin, blinkState ? HIGH : LOW);
    } else {
      digitalWrite(bulb2Pin, LOW);
    }
  }

  delay(50);
}
